# 데이터베이스
DATABASE_URL="postgresql://user:password@localhost:5432/board_db"

# JWT
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="1d"

# AWS
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET="your-s3-bucket-name"

# 관리자
ADMIN_EMAILS="admin@example.com"

# 서버
PORT=3000
CORS_ORIGIN="http://localhost:3000"

# === GitHub Actions CD Secrets (EC2 서버에 직접 설정 — .env에는 불필요) ===
# GitHub Repository → Settings → Secrets and variables → Actions 에 등록
#
# EC2_HOST=your-ec2-public-ip-or-domain
# EC2_USER=ec2-user
# EC2_SSH_KEY=(GitHub Secret으로 등록, PEM 파일 내용 전체)
# EC2_PORT=22
# EC2_APP_DIR=/home/ec2-user/aws-board-backend
# EC2_APP_NAME=board-api
